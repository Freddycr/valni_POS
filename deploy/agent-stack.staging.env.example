# Supabase Postgres connection
DATABASE_URL=postgresql://postgres:password@db.host:5432/postgres

# Agent model key
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AGENT_MODEL=openrouter/google/gemini-2.0-flash-001

# Optional defaults
BUSINESS_TIMEZONE=America/Lima
DEFAULT_COMPANY_ID=

# Optional API key protection for Klisk endpoints
KLISK_API_KEY=
KLISK_CHAT_KEY=
KLISK_WIDGET_KEY=

# Optional tuning
SEMANTIC_MAX_LIMIT=500
SEMANTIC_TIMEOUT_MS=5000
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_TTL_MS=30000
SEMANTIC_CACHE_MAX_ENTRIES=200

# Public ports
SEMANTIC_PUBLIC_PORT=8787
KLISK_PUBLIC_PORT=8080
